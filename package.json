{
  "name": "vextris",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:smoke:preview": "node scripts/smoke-test.mjs --mode=preview",
    "test:smoke:dev": "node scripts/smoke-test.mjs --mode=dev",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": ">=22.12.0",
    "eslint": "^10.5.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "phaser": "^3.80.0",
    "playwright": "^1.58.2",
    "tone": "^15.1.22"
  }
}
